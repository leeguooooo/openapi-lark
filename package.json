{
  "name": "openapi-lark",
  "version": "0.5.0",
  "description": "Sync OpenAPI (Swagger) spec to Lark / Feishu wiki & docx — one wiki node per endpoint, auto-grouped by tag. Drop-in yapi replacement for chanfana / Hono / FastAPI / NestJS Swagger projects.",
  "keywords": [
    "openapi",
    "swagger",
    "lark",
    "feishu",
    "lark-cli",
    "wiki",
    "docx",
    "api-docs",
    "documentation",
    "sync",
    "yapi",
    "yapi-alternative",
    "openapi-to-wiki",
    "openapi-to-lark",
    "openapi-to-feishu",
    "swagger-to-feishu",
    "chanfana",
    "hono",
    "fastapi",
    "nestjs-swagger",
    "widdershins",
    "claude-code",
    "claude-skill"
  ],
  "homepage": "https://github.com/leeguooooo/openapi-lark#readme",
  "bugs": "https://github.com/leeguooooo/openapi-lark/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "openapi-lark": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "tsc || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "commander": "^12.1.0",
    "p-limit": "^6.1.0",
    "remark-parse": "^11.0.0",
    "semver": "^7.6.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "widdershins": "^4.0.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.8",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leeguooooo/openapi-lark.git"
  }
}
